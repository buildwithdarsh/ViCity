# App
NODE_ENV=development
PORT=3001
APP_URL=https://vicity.build.withdarsh.com
API_VERSION=v1

# Central Backend URL (Darsh Gupta)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://vicity:vicity@localhost:5432/vicity?schema=public

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Email (Resend)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=hello@build.withdarsh.com

# Storage
STORAGE_PROVIDER=local
# AWS S3 (when STORAGE_PROVIDER=s3)
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Cloudinary (when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_URL=

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Sentry (optional)
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
